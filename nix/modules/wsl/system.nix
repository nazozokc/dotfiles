{ pkgs, ... }:

{
  ########################################
  # WSL 専用パッケージ
  ########################################
  home.packages = with pkgs; [
    # アーカイブ（Linuxから引き継ぎ）
    unzip
    zip

    # ネットワーク
    nmap
  ];

  ########################################
  # WSL 向け環境変数
  ########################################
  home.sessionVariables = {
    WSLENV = "HOME/p:USERPROFILE/p";
  };
}
